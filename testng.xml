<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Loan Origination Test Suite" parallel="false" thread-count="1" verbose="1">
    
    <listeners>
        <listener class-name="listeners.ExtentReportListener"/>
    </listeners>
    
    <!-- Customer Registration Regression Suite -->
    <test name="Customer Registration - Happy Path">
        <classes>
            <class name="tests.CustomerRegistrationTest">
                <methods>
                    <include name="testSuccessfulCustomerRegistration"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Customer Registration - Field Validation">
        <classes>
            <class name="tests.CustomerRegistrationValidationTest">
                <methods>
                    <include name="testCustomerRegistrationFieldValidation"/>
                    <include name="testAllMandatoryFieldsEmpty"/>
                    <include name="testErrorMessagePersistence"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Customer Registration - Duplicate and Boundary">
        <classes>
            <class name="tests.CustomerRegistrationDuplicateBoundaryTest">
                <methods>
                    <include name="testDuplicateCustomerRegistration"/>
                    <include name="testCustomerRegistrationBoundaryValues"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Customer Data-Driven Tests">
        <classes>
            <class name="tests.CustomerDataDrivenTest">
                <methods>
                    <include name="testCustomerValidationWithExcel"/>
                    <include name="testCustomerValidationWithJSON"/>
                    <include name="testCustomerProfileCompleteness"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <!-- Framework Validation Tests (Optional - for framework verification) -->
    <test name="Page Object Framework Tests" enabled="false">
        <classes>
            <class name="tests.PageObjectFrameworkTest"/>
        </classes>
    </test>
    
    <test name="Framework Validation Tests" enabled="false">
        <classes>
            <class name="tests.FrameworkValidationTest"/>
        </classes>
    </test>
    
    <test name="Sample Tests" enabled="false">
        <classes>
            <class name="tests.SampleTest"/>
        </classes>
    </test>
    
    <!-- Loan and Payment Tests (Disabled - Not part of Customer Registration suite) -->
    <test name="Loan Data-Driven Tests" enabled="false">
        <classes>
            <class name="tests.LoanDataDrivenTest">
                <methods>
                    <include name="testLoanApplicationWithExcel"/>
                    <include name="testLoanApplicationWithJSON"/>
                    <include name="testLoanProcessingWithExpectedResults"/>
                    <include name="testLoanEligibility"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Payment Data-Driven Tests" enabled="false">
        <classes>
            <class name="tests.PaymentDataDrivenTest">
                <methods>
                    <include name="testPaymentProcessingWithExcel"/>
                    <include name="testPaymentProcessingWithJSON"/>
                    <include name="testPaymentDateValidation"/>
                    <include name="testPaymentMethodConstraints"/>
                    <include name="testBalanceCalculation"/>
                    <include name="testPaymentTransactionProcessing"/>
                </methods>
            </class>
        </classes>
    </test>
    
</suite>
