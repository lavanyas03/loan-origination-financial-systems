<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Customer Registration Validation Test Suite" parallel="false" thread-count="1" verbose="2">
    
    <listeners>
        <listener class-name="listeners.ExtentReportListener"/>
    </listeners>
    
    <!-- Customer Registration Validation Tests Only -->
    <test name="Customer Registration Field Validation Tests">
        <classes>
            <class name="tests.CustomerRegistrationValidationTest">
                <methods>
                    <!-- Data-driven test: 27 validation scenarios from JSON -->
                    <include name="testCustomerRegistrationFieldValidation"/>
                    
                    <!-- All mandatory fields empty test -->
                    <include name="testAllMandatoryFieldsEmpty"/>
                    
                    <!-- Error message persistence test -->
                    <include name="testErrorMessagePersistence"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <!-- Customer Registration Duplicate and Boundary Tests -->
    <test name="Customer Registration Duplicate and Boundary Tests">
        <classes>
            <class name="tests.CustomerRegistrationDuplicateBoundaryTest">
                <methods>
                    <!-- Duplicate customer registration test -->
                    <include name="testDuplicateCustomerRegistration"/>
                    
                    <!-- Boundary value test -->
                    <include name="testCustomerRegistrationBoundaryValues"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <!-- Test Groups Configuration -->
    <test name="Validation Tests by Group">
        <groups>
            <run>
                <include name="validation"/>
                <include name="negative"/>
                <include name="boundary"/>
                <include name="duplicate"/>
            </run>
        </groups>
        <classes>
            <class name="tests.CustomerRegistrationValidationTest"/>
            <class name="tests.CustomerRegistrationDuplicateBoundaryTest"/>
        </classes>
    </test>
    
</suite>
